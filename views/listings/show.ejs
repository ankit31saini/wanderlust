<% layout("/layouts/boilerplate") %>
<script>
    const listings = <%- JSON.stringify(listings) %> ;
</script>
<div class="row">
    <div class="col-8 offset-3 mt-3 mb-3"> 
        <h3><%=listings.title%></h3>
    </div>
        <div class="card col-6 offset-3 show-card listing-card" >
            <img src="<%=listings.image.url%>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body">
                <p class="card-text"><i><b> <%= listings.owner.username %> </b></i></p>
                <p class="card-text"> <%= listings.description %> </p>
                <p class="card-text"> &#8377;<%= listings.price.toLocaleString("en-IN") %></p>
                <p class="card-text"><%= listings.location %></p>
                <p class="card-text"><%= listings.country %> </p>
                    
            </div>
        </div>
        <% if(currUser && currUser._id.equals(listings.owner._id)){ %>
        <div class="btns mb-3">
            <a href="/listings/<%= listings._id %>/edit" class="btn btn-dark edit-btn col-1 offset-3">edit</a>
            <form method="POST" action="/listings/<%=listings._id%>?_method=DELETE">
                <button class="btn btn-dark offset-5">delete</button>
            </form>
            
        </div>
        
        <% } %>

        <div class="col-8 offset-3 mt-3 mb-3" >
            
            <% if(currUser){ %>
            <hr>
            <h4>Leave a review</h4>
            <form action="/listings/<%=listings._id%>/review" method="POST" novalidate class="needs-validation">
                <!-- <div class="mt-3 mb-3">
                    <label for="rating" class="form-label">Rating</label>
                    <input type="range" min="1" max="5" id="rating" name="review[rating]" class="form-range">
                </div> -->
                <div class="mt-3 mb-3">
                <label for="rating" class="form-label">Rating</label>
                <fieldset class="starability-slot">                    
                    <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                    <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                    <label for="first-rate1" title="Terrible">1 star</label>
                    <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                    <label for="first-rate2" title="Not good">2 stars</label>
                    <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                    <label for="first-rate3" title="Average">3 stars</label>
                    <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                    <label for="first-rate4" title="Very good">4 stars</label>
                    <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                    <label for="first-rate5" title="Amazing">5 stars</label>
                </fieldset>
                </div>
                <div class="mt-3 mb-3">
                    <label for="comment" class="form-label">Comment:</label>
                    <textarea id="comment" col="5" rows="9" name="review[comment]" class="form-control" required ></textarea>
                    <div class="invalid-feedback">please add some comment for review</div>
                </div>
                <button class="btn btn-outline-dark mt-3">submit</button>
            </form>
            <hr>
            <% } %>
            <% if(listings.review.length > 0){  %>
            <div class="row">
            <p><b>All Reviews</b></p>
            <% for(review of listings.review){ %>
                
                <div class="card col-5 ms-3 mb-3" style="width: 18rem;">
                    <div class="card-body">
                        <h5 class="card-title">@<%= review.author.username %></h5>
                        <p class="starability-result" data-rating=<%= review.rating %>>  </p>
                        <p class="card-text"><%=review.comment%></p>
                        
                        <form class="mb-3" method="POST" action="/listings/<%=listings._id%>/review/<%=review._id%>?_method=DELETE">
                            <button class="btn btn-sm btn-dark">Delete</button>
                        </form>
                    </div>
                </div>
            <% } %>
            </div>
            <% } %>
        </div>
        <div class="col-8 offset-3 mt-3 mb-3">
            <div id="map" style="width: 100%; height: 500px"></div>
            <!-- <div id="map"></div> -->
        </div>
</div>
<!-- <script src="/js/map.js"></script> -->